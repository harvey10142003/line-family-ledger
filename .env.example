# ============== Database ==============
DATABASE_URL="postgresql://user:password@host:5432/family_ledger"

# ============== Server ==============
PORT=3000
NODE_ENV=development
PUBLIC_URL=https://your-domain.zeabur.app

# ============== LINE ==============
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
LINE_LIFF_ID=1234567890-AbCdEfGh

# ============== AI ==============
# Google Gemini 2.5 Flash — 同時負責文字記帳 parse + 收據圖片 OCR
GEMINI_API_KEY=AIzaSyXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.5-flash

# ============== 定期提醒（階段 3b）==============
# in-process node-cron 預設開啟：每月 1 號 09:00 推月結、每週一 09:00 推預算週報（台北時區）
# 若改用外部排程器（Zeabur cron job 打 /jobs/*），設成 true 關閉內建 cron 避免重複推播
DISABLE_INPROCESS_CRON=false
# 設了才會啟用 POST /jobs/:task 手動/外部觸發端點，並用 x-cron-secret header 驗證
CRON_SECRET=

# ============== Web (Next.js) ==============
NEXT_PUBLIC_LIFF_ID=1234567890-AbCdEfGh
NEXT_PUBLIC_API_BASE=https://your-domain.zeabur.app
