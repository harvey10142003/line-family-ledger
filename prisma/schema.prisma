// LINE 家庭共同記帳 — Prisma schema
// 一對多架構：一個 LINE@ 服務多個家庭，使用 6 碼家庭碼識別

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== 家庭 =====
model Family {
  id          String   @id @default(cuid())
  name        String
  familyCode  String   @unique // 6 碼大寫英數，如 "AB12CD"
  ownerLineId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      FamilyMember[]
  categories   Category[]
  transactions Transaction[]
  invites      InviteLink[]
  budgets      Budget[]
  accounts     Account[]
  transfers    Transfer[]

  @@index([ownerLineId])
}

// ===== 家庭成員（綁定 LINE userId）=====
model FamilyMember {
  id          String   @id @default(cuid())
  familyId    String
  lineUserId  String
  displayName String
  avatarUrl   String?
  role        Role     @default(MEMBER)
  joinedAt    DateTime @default(now())

  family       Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  transfers    Transfer[]

  @@unique([familyId, lineUserId])
  @@index([lineUserId])
}

enum Role {
  OWNER
  MEMBER
}

// ===== 分類 =====
model Category {
  id        String       @id @default(cuid())
  familyId  String
  name      String
  icon      String?
  type      CategoryType
  isDefault Boolean      @default(false)
  sortOrder Int          @default(0)

  family       Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@unique([familyId, name])
}

enum CategoryType {
  EXPENSE
  INCOME
}

// ===== 交易 =====
model Transaction {
  id         String            @id @default(cuid())
  familyId   String
  memberId   String
  categoryId String
  accountId  String? // 付款帳戶（現金/銀行/信用卡/電子支付）；null = 未指定（含舊資料）
  amount     Decimal           @db.Decimal(12, 2)
  note       String?
  paidAt     DateTime
  source     TransactionSource @default(TEXT)
  createdAt  DateTime          @default(now())

  family   Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member   FamilyMember @relation(fields: [memberId], references: [id])
  category Category     @relation(fields: [categoryId], references: [id])
  account  Account?     @relation(fields: [accountId], references: [id])
  receipt  Receipt?

  @@index([familyId, paidAt])
  @@index([familyId, categoryId])
  @@index([memberId])
  @@index([accountId])
}

enum TransactionSource {
  TEXT   // LINE 文字訊息輸入
  PHOTO  // 收據拍照辨識
  MANUAL // LIFF 表單手動輸入
}

// ===== 預算（每月循環）=====
model Budget {
  id         String   @id @default(cuid())
  familyId   String
  categoryId String? // null = 整體月預算；有值 = 該分類月預算
  amount     Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  family   Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([familyId])
}

// ===== 帳戶（= 付款方式：現金/銀行/信用卡/電子支付）=====
model Account {
  id             String      @id @default(cuid())
  familyId       String
  name           String
  type           AccountType @default(CASH)
  icon           String?
  openingBalance Decimal     @db.Decimal(12, 2) @default(0) // 期初餘額
  isDefault      Boolean     @default(false) // 記帳未指定時的預設帳戶
  isArchived     Boolean     @default(false)
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())

  family        Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  transfersOut  Transfer[]    @relation("TransferFrom")
  transfersIn   Transfer[]    @relation("TransferTo")

  @@unique([familyId, name])
  @@index([familyId])
}

enum AccountType {
  CASH         // 現金
  BANK         // 銀行
  CREDIT_CARD  // 信用卡
  EPAYMENT     // 電子支付（LINE Pay / 街口…）
  OTHER
}

// ===== 帳戶間轉帳（不計入收支，只移動餘額）=====
model Transfer {
  id            String   @id @default(cuid())
  familyId      String
  memberId      String
  fromAccountId String
  toAccountId   String
  amount        Decimal  @db.Decimal(12, 2)
  note          String?
  transferredAt DateTime
  createdAt     DateTime @default(now())

  family      Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member      FamilyMember @relation(fields: [memberId], references: [id])
  fromAccount Account      @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccount   Account      @relation("TransferTo", fields: [toAccountId], references: [id])

  @@index([familyId, transferredAt])
}

// ===== 收據圖片 =====
model Receipt {
  id            String   @id @default(cuid())
  transactionId String   @unique
  imageUrl      String
  aiParsedJson  Json?
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

// ===== 邀請連結 =====
model InviteLink {
  id        String    @id @default(cuid())
  familyId  String
  code      String    @unique
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  usedCount Int       @default(0)

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
}
