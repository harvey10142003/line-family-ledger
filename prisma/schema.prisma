// LINE 家庭共同記帳 — Prisma schema
// 一對多架構：一個 LINE@ 服務多個家庭，使用 6 碼家庭碼識別

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== 家庭 =====
model Family {
  id          String   @id @default(cuid())
  name        String
  familyCode  String   @unique // 6 碼大寫英數，如 "AB12CD"
  ownerLineId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      FamilyMember[]
  categories   Category[]
  transactions Transaction[]
  invites      InviteLink[]
  budgets      Budget[]
  accounts     Account[]
  transfers    Transfer[]
  creditCards  CreditCard[]
  recurringRules RecurringRule[]

  @@index([ownerLineId])
}

// ===== 家庭成員（綁定 LINE userId）=====
model FamilyMember {
  id          String   @id @default(cuid())
  familyId    String
  lineUserId  String
  displayName String
  avatarUrl   String?
  role        Role     @default(MEMBER)
  joinedAt    DateTime @default(now())

  family       Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  transfers    Transfer[]

  @@unique([familyId, lineUserId])
  @@index([lineUserId])
}

enum Role {
  OWNER
  MEMBER
}

// ===== 分類 =====
model Category {
  id        String       @id @default(cuid())
  familyId  String
  name      String
  icon      String?
  type      CategoryType
  isDefault Boolean      @default(false)
  sortOrder Int          @default(0)

  family       Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@unique([familyId, name])
}

enum CategoryType {
  EXPENSE
  INCOME
}

// ===== 交易 =====
model Transaction {
  id         String            @id @default(cuid())
  familyId   String
  memberId   String
  categoryId String
  accountId    String? // 付款帳戶（現金/銀行/電子支付）；null = 未指定（含舊資料）
  creditCardId String? // 用信用卡付款時填此；與 accountId 二擇一
  amount     Decimal           @db.Decimal(12, 2)
  note       String?
  paidAt     DateTime
  isShared   Boolean           @default(true) // true=家庭共同(納入分帳)；false=個人支出(不分帳)
  source     TransactionSource @default(TEXT)
  createdAt  DateTime          @default(now())

  family     Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member     FamilyMember @relation(fields: [memberId], references: [id])
  category   Category     @relation(fields: [categoryId], references: [id])
  account    Account?     @relation(fields: [accountId], references: [id])
  creditCard CreditCard?  @relation(fields: [creditCardId], references: [id])
  receipt    Receipt?

  @@index([familyId, paidAt])
  @@index([familyId, categoryId])
  @@index([memberId])
  @@index([accountId])
  @@index([creditCardId])
}

enum TransactionSource {
  TEXT      // LINE 文字訊息輸入
  PHOTO     // 收據拍照辨識
  MANUAL    // LIFF 表單手動輸入
  RECURRING // 固定收支自動產生
}

// ===== 預算（每月循環）=====
model Budget {
  id         String   @id @default(cuid())
  familyId   String
  categoryId String? // null = 整體月預算；有值 = 該分類月預算
  amount     Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  family   Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([familyId])
}

// ===== 帳戶（= 付款方式：現金/銀行/信用卡/電子支付）=====
model Account {
  id             String      @id @default(cuid())
  familyId       String
  name           String
  type           AccountType @default(CASH)
  icon           String?
  openingBalance Decimal     @db.Decimal(12, 2) @default(0) // 期初餘額
  isDefault      Boolean     @default(false) // 記帳未指定時的預設帳戶
  isArchived     Boolean     @default(false)
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())

  family        Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  transfersOut  Transfer[]    @relation("TransferFrom")
  transfersIn   Transfer[]    @relation("TransferTo")

  @@unique([familyId, name])
  @@index([familyId])
}

enum AccountType {
  CASH         // 現金
  BANK         // 銀行
  CREDIT_CARD  // 信用卡
  EPAYMENT     // 電子支付（LINE Pay / 街口…）
  OTHER
}

// ===== 固定收支 / 週期記帳（每月或每週自動產生交易）=====
model RecurringRule {
  id           String        @id @default(cuid())
  familyId     String
  memberId     String // 建立者（產生的交易記在他名下）
  categoryId   String
  accountId    String?
  creditCardId String?
  amount       Decimal       @db.Decimal(12, 2)
  note         String?
  isShared     Boolean       @default(true)
  frequency    RecurringFreq @default(MONTHLY)
  dayOfMonth   Int           @default(1) // MONTHLY 用（1-31，超過月底自動clamp）
  dayOfWeek    Int           @default(1) // WEEKLY 用（0=日 .. 6=六）
  isActive     Boolean       @default(true)
  lastPostedAt DateTime? // 防同日重複產生
  createdAt    DateTime      @default(now())

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId])
}

enum RecurringFreq {
  MONTHLY
  WEEKLY
}

// ===== 信用卡（與帳戶分開：有額度/結算日/繳費日）=====
model CreditCard {
  id           String   @id @default(cuid())
  familyId     String
  name         String
  creditLimit  Decimal  @db.Decimal(12, 2) @default(0) // 額度
  statementDay Int      @default(1) // 結算日（每月幾號）
  dueDay       Int      @default(15) // 繳費日（每月幾號）
  icon         String?
  isArchived   Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  family       Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([familyId, name])
  @@index([familyId])
}

// ===== 帳戶間轉帳（不計入收支，只移動餘額）=====
model Transfer {
  id            String   @id @default(cuid())
  familyId      String
  memberId      String
  fromAccountId String
  toAccountId   String
  amount        Decimal  @db.Decimal(12, 2)
  note          String?
  transferredAt DateTime
  createdAt     DateTime @default(now())

  family      Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member      FamilyMember @relation(fields: [memberId], references: [id])
  fromAccount Account      @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccount   Account      @relation("TransferTo", fields: [toAccountId], references: [id])

  @@index([familyId, transferredAt])
}

// ===== 收據圖片 =====
model Receipt {
  id            String   @id @default(cuid())
  transactionId String   @unique
  imageUrl      String
  aiParsedJson  Json?
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

// ===== 邀請連結 =====
model InviteLink {
  id        String    @id @default(cuid())
  familyId  String
  code      String    @unique
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  usedCount Int       @default(0)

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
}
